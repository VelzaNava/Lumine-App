<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for backend API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required for AR camera -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Required for profile picture selection -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Camera feature required -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LumineApp"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31"
        tools:replace="android:theme">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LumineApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Override unityLibrary's UnityPlayerActivity declaration:
             The library manifest gives it a LAUNCHER intent-filter, which causes a
             second app icon. We merge-override to strip that filter entirely.
             UnityPlayer is embedded as a View inside MainActivity — it never needs
             to be launched as a standalone activity. -->
        <activity
            android:name="com.unity3d.player.UnityPlayerActivity"
            tools:node="merge">
            <intent-filter tools:node="removeAll"/>
        </activity>

        <!-- Disable Unity splash screen at application level.
             The library manifest enables it (unity.splash-enable=True), which would
             make Unity look for a unity_static_splash drawable that does not exist
             in our app, causing a crash. We embed Unity as a transparent overlay,
             so no splash is needed or desired. -->
        <meta-data
            android:name="unity.splash-enable"
            android:value="False"
            tools:node="replace"/>
        <!-- Also disable fullscreen launch — Unity is a view layer, not a full activity -->
        <meta-data
            android:name="unity.launch-fullscreen"
            android:value="False"
            tools:node="replace"/>
        <!-- Force OpenGL ES — disable Vulkan to prevent AHardwareBuffer allocation failures.
             Unity 2022.3 on Vivo Y100 (Adreno GPU) crashes when trying to allocate buffers
             in pixel formats 0x38 (56) / 0x3b (59) with usage 0xb00 (SAMPLED|FRAMEBUFFER|OVERLAY).
             Disabling Vulkan forces Unity through the GLES path which uses RGBA_8888 instead. -->
        <meta-data
            android:name="unity.disable-vulkan"
            android:value="true"
            tools:node="replace"/>
    </application>

</manifest>